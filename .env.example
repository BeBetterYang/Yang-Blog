# Server-only. Create an internal Notion integration, copy its secret, and
# invite that integration to the Notion database page.
NOTION_TOKEN="secret_xxx"

# The database id from the Notion table URL.
NOTION_DATABASE_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional cache window for Notion database metadata in serverless/runtime APIs.
NOTION_CACHE_TTL_MS="60000"

# Public browser config. These are safe to expose because Vite embeds VITE_* vars.
VITE_BLOG_DESCRIPTION="以 Notion 为内容源的极简博客。"
